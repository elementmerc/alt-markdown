  },
  {
    "name": "footnote",
    "input": "a[^1]\n\n[^1]: a note\n",
    "contains": ["<sup class=\"footnote-ref\"><a href=\"#fn-1\">1</a></sup>", "id=\"fn-1\""]
  },
  {
    "name": "task-list",
